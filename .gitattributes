# Normalize line endings to LF in repository
* text=auto eol=lf

# Force LF for source files
*.vue      text eol=lf
*.ts       text eol=lf
*.js       text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.sql      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.drawio   text eol=lf
*.example  text eol=lf
*.gitignore text eol=lf

# Binary files — no text conversion
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
