# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=remview
POSTGRES_USER=remview
POSTGRES_PASSWORD=remview123

# ── pgAdmin (optional) ────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@remview.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_generate_random_64_byte_hex
JWT_EXPIRES_IN=8h

# ── LabVIEW Webservice (optional – for dev with real backend) ─────────────────
NUXT_PUBLIC_LABVIEW_BASE_URL=
NUXT_PUBLIC_WS_URL=
NUXT_PUBLIC_WS_PATH=/ws
